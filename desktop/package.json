{
  "name": "positronic-node",
  "version": "0.3.2",
  "description": "Positronic AI-Validated Blockchain Node",
  "author": "Positronic AI <support@positronic-ai.network>",
  "main": "main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"vite --config vite.renderer.config.js --port 5173\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build --config vite.renderer.config.js",
    "build": "npm run build:renderer && electron-builder",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:linux": "npm run build:renderer && electron-builder --linux",
    "dev:renderer": "vite --config vite.renderer.config.js --port 5173"
  },
  "dependencies": {
    "@noble/ed25519": "^3.0.1",
    "@noble/hashes": "^2.0.1",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "lucide-react": "^0.474.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.14.1",
    "vite": "^6.0.0",
    "wait-on": "^8.0.2"
  }
}
